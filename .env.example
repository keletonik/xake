# XAKE environment variables
# Copy to .env.local and fill in values for the stages you're working on.
# Stage 0 does not require any of these to boot the web shell.

# ---- Core ----
NODE_ENV=development
XAKE_ENV=paper                 # paper | live — never flip to live without partner readiness
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ---- Auth (Stage 3) ----
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ---- Database (Stage 3+) ----
DATABASE_URL=postgres://xake:xake@localhost:5432/xake
TIMESCALE_ENABLED=false

# ---- Redis (Stage 7+) ----
REDIS_URL=redis://localhost:6379

# ---- Market data providers (Stage 4+) ----
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_FEED=iex                # iex | sip (sip needs licensing)
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
BENZINGA_API_KEY=
TRADING_ECONOMICS_API_KEY=
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
BINANCE_TESTNET_WS_URL=wss://testnet.binance.vision/ws

# ---- AI (Stage 8) ----
ANTHROPIC_API_KEY=
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
CLAUDE_HEAVY_MODEL=claude-opus-4-7

# ---- Observability (Stage 10) ----
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=xake

# ---- Feature flags ----
FEATURE_AI_ASSISTANT=false
FEATURE_LIVE_EXECUTION=false   # keep false; live is gated on licensing
FEATURE_NEWS_LANE=false
