# XAKE environment variables.
# Copy to .env.local (or set in Vercel/Replit Secrets) for the bits you need.
# Local dev works with zero configuration — defaults cover it.

# ---- Platform ----
DEPLOY_TARGET=node              # node | vercel | replit
NODE_ENV=development
XAKE_ENV=paper                  # paper | live — NEVER set live without partner+licensing readiness
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=                # comma-separated; defaults to APP_URL + localhost

# ---- Embedded vs external API ----
# Leave unset to run the API embedded inside Next.js (matches Vercel).
# Set to http://localhost:4000 to front an external Hono server (matches Replit).
NEXT_PUBLIC_API_URL=

# ---- Auth ----
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ---- Database ----
DATABASE_URL=                   # postgres://user:pass@host:5432/xake
DATABASE_POOL_MAX=5             # drop to 1 on serverless

# ---- Redis (optional, long-running hosts only) ----
REDIS_URL=

# ---- Market data providers ----
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_FEED=iex                 # iex | sip (sip requires licensing)
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
BENZINGA_API_KEY=
TRADING_ECONOMICS_API_KEY=
ENABLE_COINBASE_FEED=false      # public WS — safe to enable on long-running hosts

# ---- AI ----
ANTHROPIC_API_KEY=
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
CLAUDE_HEAVY_MODEL=claude-opus-4-7

# ---- Cron ----
CRON_SECRET=                    # required for Vercel crons; enforced if set

# ---- Observability ----
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=xake

# ---- Feature flags ----
FEATURE_AI_ASSISTANT=true
FEATURE_LIVE_EXECUTION=false    # stays off; gated on licensing
FEATURE_NEWS_LANE=false

# ---- Demo ----
DEMO_ACCOUNT_ID=demo-account    # used only when Clerk is not configured
