# XAKE environment (Vercel-native)

# App
NEXT_PUBLIC_APP_NAME=XAKE
NEXT_PUBLIC_ENVIRONMENT=paper

# Anthropic (AI assistant)
# If omitted, the assistant falls back to a deterministic stub stream.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001

# Cron protection
# Vercel Cron sends the bearer in `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=

# Feature flags
ENABLE_COINBASE_FEED=false
