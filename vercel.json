{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @xake/web build && node scripts/check-client-bundle.mjs",
  "installCommand": "corepack enable && corepack prepare pnpm@9.12.0 --activate && pnpm install --no-frozen-lockfile",
  "framework": "nextjs",
  "outputDirectory": "apps/web/.next",
  "crons": [
    {
      "path": "/api/v1/cron/evaluate-alerts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/v1/cron/health-sweep",
      "schedule": "*/10 * * * *"
    }
  ]
}
