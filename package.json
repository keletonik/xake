{
  "name": "xake",
  "version": "0.0.0",
  "private": true,
  "description": "XAKE — premium dark-theme trading decision cockpit",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @xake/web dev",
    "dev:api": "pnpm --filter @xake/api dev",
    "dev:worker": "pnpm --filter @xake/worker dev",
    "build": "pnpm -r --if-present build",
    "start": "pnpm --filter @xake/web start",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "clean": "pnpm -r --if-present clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
