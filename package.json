{
  "name": "xake",
  "version": "0.0.0",
  "private": true,
  "description": "XAKE — premium dark-theme trading decision cockpit",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": "20.x",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @xake/web dev",
    "dev:api": "pnpm --filter @xake/api dev",
    "dev:worker": "pnpm --filter @xake/worker dev",
    "build": "pnpm -r --if-present build && pnpm check:bundle",
    "check:bundle": "node scripts/check-client-bundle.mjs",
    "start": "pnpm --filter @xake/web start",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "migrate": "pnpm --filter @xake/db migrate",
    "clean": "pnpm -r --if-present clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.2"
  }
}
